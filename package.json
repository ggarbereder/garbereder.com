{
  "name": "garbereder.com",
  "type": "module",
  "version": "1.0.53",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "postinstall": "patch-package",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "npx eslint",
    "lint:prettier": "prettier --check .",
    "lint:prettier:write": "prettier --write .",
    "cy:run": "cypress run --config baseUrl=http://localhost:4321",
    "cy:run:visual": "cypress run --config baseUrl=http://localhost:4321 --spec 'cypress/e2e/visual/**/*.cy.js'",
    "test:e2e": "start-server-and-test dev http://localhost:4321 cy:run",
    "test:visual": "start-server-and-test dev http://localhost:4321 cy:run:visual",
    "test:visual:update": "rm -rf cypress-image-diff-screenshots/baseline && start-server-and-test dev http://localhost:4321 cy:run:visual",
    "test:coverage": "CYPRESS_COVERAGE=true start-server-and-test dev http://localhost:4321 cy:run",
    "test": "npm run lint && npm run test:e2e",
    "prepare": "npx husky",
    "security:audit": "npm audit",
    "security:outdated": "npm outdated",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{astro,json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@emnapi/wasi-threads": "1.2.2",
    "esbuild": ">=0.28.1",
    "qs": ">=6.15.2",
    "uuid": ">=11.1.1"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@astrojs/preact": "^5.1.5",
    "@cypress/code-coverage": "^4.0.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "astro": "^6.4.6",
    "cssnano": "^8.0.2",
    "cypress": "^15.17.0",
    "cypress-image-diff-js": "^2.8.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nyc": "^18.0.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.15",
    "preact": "^10.29.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.101.0",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-imagetools": "^10.0.0",
    "vite-plugin-istanbul": "^9.0.1"
  }
}
