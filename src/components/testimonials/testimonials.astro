---
import './testimonials.scss';

interface Props {
  testimonials: Array<{
    quote: string;
    source?: string;
    company?: string;
  }>;
}

const { testimonials } = Astro.props;
const testimonialCount = testimonials.length;
---

<section
  class="w-full max-w-4xl bg-slate-50/90 backdrop-blur-sm rounded-lg shadow-2xl overflow-hidden"
  aria-labelledby="testimonials-heading"
>
  <div class="testimonials-slideshow mt-8 pb-12">
    <div
      class="testimonials-viewport overflow-x-auto scroll-smooth snap-x snap-mandatory px-6 md:px-10 pb-4 scrollbar-hide outline-none focus:outline-none"
      role="region"
      aria-label="Testimonials carousel"
      tabindex="0"
    >
      <ol
        class="testimonials-track flex gap-6"
        style={`width: calc(${testimonialCount * 100}% + ${(testimonialCount - 1) * 1.5}rem)`}
      >
        {
          testimonials.map((item) => (
            <li
              class="testimonial-slide min-w-0 shrink-0 snap-center rounded-xl bg-white/80 shadow-lg border border-cyan-900/10 testimonial-card"
              style={`flex: 0 0 calc(${100 / testimonialCount}% - 1rem)`}
            >
              <blockquote class="testimonial-blockquote">
                <span class="testimonial-quote-open" aria-hidden="true">
                  "
                </span>
                <p class="testimonial-text">{item.quote}</p>
                <span class="testimonial-quote-close" aria-hidden="true">
                  "
                </span>
                {(item.source || item.company) && (
                  <footer class="testimonial-source">
                    {item.source && (
                      <span class="testimonial-role">{item.source}</span>
                    )}
                    {item.source && item.company && (
                      <span class="testimonial-sep"> at </span>
                    )}
                    {item.company && (
                      <span class="testimonial-company">{item.company}</span>
                    )}
                  </footer>
                )}
              </blockquote>
            </li>
          ))
        }
      </ol>
    </div>
    <div
      class="testimonials-nav flex items-center justify-center gap-4 mt-6"
      aria-label="Slideshow controls"
    >
      <button
        type="button"
        class="testimonials-prev w-11 h-11 rounded-full bg-cyan-900/90 text-white shadow-md hover:bg-cyan-800 focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 transition-colors disabled:opacity-40 disabled:pointer-events-none"
        aria-label="Previous testimonial"
      >
        <span aria-hidden="true">←</span>
      </button>
      <div class="testimonials-dots flex gap-2" role="tablist">
        {
          testimonials.map((_, i) => (
            <button
              type="button"
              class="testimonials-dot w-2.5 h-2.5 rounded-full bg-cyan-900/40 hover:bg-cyan-900/70 transition-all"
              role="tab"
              aria-label={`Testimonial ${i + 1}`}
              aria-selected={i === 0}
              data-index={i}
            />
          ))
        }
      </div>
      <button
        type="button"
        class="testimonials-next w-11 h-11 rounded-full bg-cyan-900/90 text-white shadow-md hover:bg-cyan-800 focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 transition-colors disabled:opacity-40 disabled:pointer-events-none"
        aria-label="Next testimonial"
      >
        <span aria-hidden="true">→</span>
      </button>
    </div>
  </div>
</section>

<script type="module" src="/scripts/testimonials.js" fetchpriority="low"></script>
