---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  /** Optional Google Fonts stylesheet URL (e.g. Fraunces). Adds preconnect + link in head. */
  extraFontUrl?: string;
  /** Optional LCP image preload: { src, srcset } so the image is discoverable from HTML immediately. */
  lcpPreload?: { src: string; srcset: string };
  /** Optional video preload URL (e.g. background hero video). */
  videoPreload?: string;
}

const {
  title = 'Gerrit Garbereder | Senior Engineering Manager',
  description = 'Senior Engineering Manager with expertise in leading cross-functional teams, project delivery, and fostering innovation. View my professional experience and contact information.',
  canonical = 'https://www.garbereder.com',
  keywords = 'Engineering Manager, Project Management, Team Leadership, Software Development, Innovation',
  extraFontUrl,
  lcpPreload,
  videoPreload,
} = Astro.props;
---

<head>
  <meta charset="utf-8" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <link
    rel="preload"
    href="https://fonts.googleapis.com/css2?family=Quicksand&display=swap"
    as="style"
  />
  {lcpPreload && (
    <link
      rel="preload"
      as="image"
      href={lcpPreload.src}
      imagesrcset={lcpPreload.srcset}
      imagesizes="(max-width: 1024px) 256px, (max-width: 1280px) 320px, 400px"
    />
  )}
  {videoPreload && (
    <link rel="preload" href={videoPreload} as="video" type="video/webm" />
  )}

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="keywords" content={keywords} />
  <meta name="author" content="Gerrit Garbereder" />
  <meta name="robots" content="index, follow" />

  <meta property="og:title" content={title} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta
    property="og:image"
    content="https://www.garbereder.com/img/portrait.jpg"
  />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Gerrit Garbereder" />

  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/x-icon" href="favicon.ico" />

  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Quicksand&display=swap"
  />

  {extraFontUrl && <link rel="stylesheet" href={extraFontUrl} />}

  <script type="module" src="/scripts/nojs.js"></script>
</head>
