---
import Portrait from './portrait.jsx';

interface Props {
  href: string;
}

const { href }: Props = Astro.props;
---

<header
  class="min-h-screen bg-gradient-to-br from-cyan-900 to-cyan-800 text-slate-300 flex flex-col justify-center pt-6 pb-6 lg:pb-0 relative overflow-hidden shadow-2xl z-2"
  role="banner"
>
  <!-- Particle canvas -->
  <canvas
    id="particle-canvas"
    class="absolute inset-0 w-full h-full z-1 pointer-events-none"
    aria-hidden="true"></canvas>

  <!-- Content overlay -->
  <div class="relative z-10">
    <div class="flex flex-col-reverse xl:flex-row justify-center">
      <div class="basis-1/4 flex flex-col justify-center">
        <h1
          class="font-light text-4xl 2xl:text-6xl text-center xl:text-left mx-4 md:mx-0"
        >
          Welcome, I am <br /><span class="text-orange-500 name-reveal"
            >Gerrit&nbsp;Garbereder</span
          >
        </h1>
        <div
          class="text-xl 2xl:text-2xl mx-auto mt-4 xl:ml-0 px-4 md:px-0 max-w-2xl"
        >
          <p
            class="contrast-more:bg-black/20 contrast-more:backdrop-blur-md contrast-more:rounded-lg contrast-more:p-4"
          >
            Senior Engineering Manager with a track record of successfully
            leading cross-functional teams in delivering complex projects
            on-time and within budget, while fostering a culture of innovation,
            collaboration, and continuous improvement.
          </p>
          <nav class="mt-8 flex flex-wrap gap-3" aria-label="Main navigation">
            <a
              href={`#${href}`}
              class="rounded-full bg-gradient-to-r from-orange-500 to-orange-400 hover:from-orange-600 hover:to-orange-500 transition-colors duration-300 px-6 py-2 text-slate-900"
              aria-label="View my resume">Resumé</a
            >
            <a
              href="//start-at-05.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border border-orange-500/60 text-orange-400 hover:bg-orange-500/20 transition-colors duration-300 px-6 py-2"
              aria-label="Start at :05 — meeting policy (opens in new window)"
              >Start at :05</a
            >
          </nav>
        </div>
      </div>
      <div
        class="flex flex-row justify-center sm:basis-1/4 mx-4 xl:mx-0 parallax-portrait"
      >
        <div class="portrait-glow-wrapper">
          <Portrait />
        </div>
      </div>
    </div>
  </div>
</header>

<script type="module" src="/scripts/particles.js"></script>
<script type="module" src="/scripts/tilt.js"></script>
