---
import Head from '../components/head.astro';
import StructuredData from '../components/structured-data.astro';
import '../styles/index.scss';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  keywords?: string;
}

const { title, description, canonical, keywords } = Astro.props;
---

<!doctype html>
<html class="scroll-smooth nojs" lang="en">
  <Head
    title={title}
    description={description}
    canonical={canonical}
    keywords={keywords}
  />
  <StructuredData />
  <body>
    <slot />
  </body>
</html>
