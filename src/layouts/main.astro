---
import Head from '../components/head.astro';
import StructuredData from '../components/structured-data.astro';
import '../styles/index.scss';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  /** Optional extra font CSS variable (e.g. '--font-fraunces') injected into head. */
  extraFontCssVariable?: string;
  /** Optional LCP image preload for the head. */
  lcpPreload?: { src: string; srcset: string };
}

const {
  title,
  description,
  canonical,
  keywords,
  extraFontCssVariable,
  lcpPreload,
} = Astro.props;
---

<!doctype html>
<html class="scroll-smooth nojs" lang="en">
  <Head
    title={title}
    description={description}
    canonical={canonical}
    keywords={keywords}
    extraFontCssVariable={extraFontCssVariable}
    lcpPreload={lcpPreload}
  />
  <StructuredData />
  <body>
    <slot />
  </body>
</html>
